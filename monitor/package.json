{
  "name": "ralph-monitor",
  "version": "0.1.0",
  "description": "Real-time monitoring dashboard for Claude Code sessions",
  "type": "module",
  "bin": {
    "ralph-monitor": "./src/cli/index.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "init": "node src/cli/index.js init",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/websocket": "^11.0.2",
    "@fastify/static": "^8.1.0",
    "sql.js": "^1.12.0",
    "chokidar": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "@tremor/react": "^3.18.7",
    "tailwindcss": "^3.4.17",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "@vitejs/plugin-react": "^4.3.4",
    "vitest": "^3.0.4",
    "postcss": "^8.5.1",
    "autoprefixer": "^10.4.20",
    "tsx": "^4.19.2",
    "concurrently": "^9.1.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.12.0",
    "@types/uuid": "^10.0.0"
  }
}
